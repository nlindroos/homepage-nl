{
  "name": "homepage-nl",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.13"
  },
  "browserslist": [
    "defaults",
    "not dead",
    "not op_mini all",
    "not kaios > 0"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "check": "npm run typecheck && biome check . && npm run lint:css",
    "format": "biome format --write .",
    "lint": "biome lint . && npm run lint:css",
    "lint:css": "stylelint \"**/*.{css,astro}\""
  },
  "dependencies": {
    "astro": "6.1.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@biomejs/biome": "2.4.12",
    "lightningcss": "1.32.0",
    "postcss-html": "1.8.1",
    "stylelint": "17.8.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-no-unsupported-browser-features": "8.1.1"
  }
}
